#include <stdio.h>

int main() {
    int n, i, tq;
    int bt[10], rem_bt[10], wt[10], tat[10], rt[10], ct[10];
    int first_response[10];
    int time = 0, completed = 0;
    float avg_wt = 0, avg_tat = 0, avg_rt = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter burst time of each process:\n");
    for(i = 0; i < n; i++) {
        printf("Process %d: ", i + 1);
        scanf("%d", &bt[i]);
        rem_bt[i] = bt[i];
        first_response[i] = -1;
    }

    printf("Enter time quantum: ");
    scanf("%d", &tq);

    while(completed < n) {
        for(i = 0; i < n; i++) {
            if(rem_bt[i] > 0) {
                if(first_response[i] == -1)
                    first_response[i] = time;

                if(rem_bt[i] > tq) {
                    time += tq;
                    rem_bt[i] -= tq;
                } else {
                    time += rem_bt[i];
                    rem_bt[i] = 0;
                    ct[i] = time;
                    completed++;
                }
            }
        }
    }

    for(i = 0; i < n; i++) {
        tat[i] = ct[i];
        wt[i] = tat[i] - bt[i];
        rt[i] = first_response[i];

        avg_wt += wt[i];
        avg_tat += tat[i];
        avg_rt += rt[i];
    }

    avg_wt /= n;
    avg_tat /= n;
    avg_rt /= n;

    printf("\nProcess\tBT\tWT\tTAT\tRT\tCT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n", i + 1, bt[i], wt[i], tat[i], rt[i], ct[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt);
    printf("\nAverage Turnaround Time = %.2f", avg_tat);
    printf("\nAverage Response Time = %.2f\n", avg_rt);

    return 0;
}
