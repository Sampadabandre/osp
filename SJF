#include <stdio.h>

int main() {
    int n, i, j;
    int bt[10], wt[10], tat[10], rt[10], ct[10];
    float avg_wt = 0, avg_tat = 0, avg_rt = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter burst time of each process:\n");
    for(i = 0; i < n; i++) {
        printf("Process %d: ", i + 1);
        scanf("%d", &bt[i]);
    }


    for(i = 0; i < n - 1; i++) {
        for(j = i + 1; j < n; j++) {
            if(bt[i] > bt[j]) {
                int temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;
            }
        }
    }



    wt[0] = 0;
    rt[0] = 0;
    ct[0] = bt[0];


    for(i = 1; i < n; i++) {
        wt[i] = wt[i - 1] + bt[i - 1];
        rt[i] = wt[i];                 
        ct[i] = ct[i - 1] + bt[i];
    }

    for(i = 0; i < n; i++) {
        tat[i] = ct[i];

        avg_wt += wt[i];
        avg_tat += tat[i];
        avg_rt += rt[i];
    }

    avg_wt /= n;
    avg_tat /= n;
    avg_rt /= n;

    printf("\nProcess\tBT\tWT\tTAT\tRT\tCT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\n", i + 1, bt[i], wt[i], tat[i], rt[i], ct[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt);
    printf("\nAverage Turnaround Time = %.2f", avg_tat);
    printf("\nAverage Response Time = %.2f\n", avg_rt);

    return 0;
}
