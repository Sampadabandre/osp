#include <stdio.h>

int main() {
    int n, i, j, idx;
    int bt[10], pr[10], wt[10], tat[10], rt[10], ct[10];
    int done[10] = {0};
    float avg_wt = 0, avg_tat = 0, avg_rt = 0;
    int time = 0, completed = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter burst time and priority of each process:\n");
    for(i = 0; i < n; i++) {
        printf("Process %d (BT PR): ", i + 1);
        scanf("%d %d", &bt[i], &pr[i]);
    }

    while(completed != n) {
        idx = -1;

        for(i = 0; i < n; i++) {
            if(done[i] == 0) {
                if(idx == -1 || pr[i] < pr[idx]) {
                    idx = i;
                }
            }
        }

        wt[idx] = time;
        rt[idx] = time;
        time += bt[idx];
        ct[idx] = time;
        tat[idx] = ct[idx];

        done[idx] = 1;
        completed++;

        avg_wt += wt[idx];
        avg_tat += tat[idx];
        avg_rt += rt[idx];
    }

    avg_wt /= n;
    avg_tat /= n;
    avg_rt /= n;

    printf("\nProcess\tBT\tPR\tWT\tTAT\tRT\tCT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\t%d\t%d\t%d\n", i + 1, bt[i], pr[i], wt[i], tat[i], rt[i], ct[i]);
    }

    printf("\nAverage Waiting Time = %.2f", avg_wt);
    printf("\nAverage Turnaround Time = %.2f", avg_tat);
    printf("\nAverage Response Time = %.2f\n", avg_rt);

    return 0;
}
