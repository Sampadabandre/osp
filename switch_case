#include <stdio.h>

int main() {
    int choice;

    printf("Enter a number (1-3): ");
    scanf("%d", &choice);

    switch(choice) {
        case 1:
            printf("You selected ONE\n");
            break;
        case 2:
            printf("You selected TWO\n");
            break;
        case 3:
            printf("You selected THREE\n");
            break;
        default:
            printf("Invalid choice\n");
    }

    return 0;
}
